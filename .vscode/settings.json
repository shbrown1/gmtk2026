{
    "files.exclude": {
        "**/*.meta": true,
        "Library/": true,
        "Temp/": true,
        "obj/": true,
        "Logs/": true
    },
    "files.associations": {
        "*.asmdef": "json",
        "*.asmref": "json"
    },
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "*.sln": "*.csproj",
        "*.slnx": "*.csproj"
    },
    "dotnet.defaultSolution": "gmtk2026.slnx",
    "search.exclude": {
        "Library/": true,
        "Temp/": true
    }
}